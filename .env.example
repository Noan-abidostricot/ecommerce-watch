# Base de données PostgreSQL (driver async)
DATABASE_URL=postgresql+asyncpg://watch_user:watch_pass@localhost:5432/ecommerce_watch

# Redis (broker Celery)
REDIS_URL=redis://localhost:6379/0

# SMTP (envoi des alertes email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=ton.email@example.com
SMTP_PASSWORD=mot_de_passe_application
SMTP_FROM=ton.email@example.com

# Sécurité
API_SECRET_KEY=change_moi_avec_une_chaine_aleatoire_longue

# Divers
SCRAPE_INTERVAL_HOURS=6
LOG_LEVEL=INFO

ALERT_RECIPIENT=ton.email@example.com
